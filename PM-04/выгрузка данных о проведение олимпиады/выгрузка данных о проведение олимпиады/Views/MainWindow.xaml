<Window x:Class="выгрузка_данных_о_проведение_олимпиады.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Выгрузка данных о проведении олимпиады"
        Height="700" Width="1180"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#D32F2F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="LightBlue"/>
                    <Setter Property="BorderBrush" Value="DarkBlue"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="AliceBlue"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Предмет:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Subjects}" SelectedItem="{Binding SelectedSubject}" Width="200"/>
                <Separator Margin="10,0" VerticalAlignment="Center" Height="30"/>
                <TextBlock Text="Класс олимпиады:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Grades}" SelectedItem="{Binding SelectedGrade}" Width="80"/>
                <Separator Margin="20,0" VerticalAlignment="Center" Height="30"/>
                <TextBlock Text="Учреждение:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBox Text="{Binding InstitutionName, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,10,0"/>
                <TextBlock Text="Адрес:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBox Text="{Binding InstitutionAddress, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
            </StackPanel>
        </Border>

        <!-- Панель кнопок + поиск -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{Binding AddRowCommand}" Content="➕ Добавить строку" Style="{StaticResource ActionButton}"/>
            <Button Grid.Column="1" Command="{Binding DeleteRowCommand}" Content="❌ Удалить строку" Style="{StaticResource DangerButton}"/>

            <!-- Поиск ученика -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                <TextBlock Text="Поиск ученика:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="SearchComboBox"
                          Width="250" 
                          IsEditable="True"
                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding FilteredRows}"
                          SelectedItem="{Binding SelectedSearchRow}"
                          IsDropDownOpen="{Binding IsDropDownOpen, Mode=TwoWay}"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          GotFocus="SearchComboBox_GotFocus"
                          Loaded="SearchComboBox_Loaded"
                          PreviewMouseLeftButtonDown="SearchComboBox_PreviewMouseLeftButtonDown"
                          DropDownClosed="SearchComboBox_DropDownClosed"
                          PreviewKeyDown="SearchComboBox_PreviewKeyDown">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StudentLastName}" Width="100"/>
                                <TextBlock Text="{Binding StudentFirstName}" Width="80"/>
                                <TextBlock Text="{Binding StudentPatronymic}" Width="80"/>
                                <TextBlock Text="{Binding StudentGrade}" Width="50" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Кнопки Excel и Сохранить -->
            <Button Grid.Column="4" Content="📂 Загрузить из Excel" Style="{StaticResource ActionButton}" Command="{Binding ImportExcelCommand}"/>
            <Button Grid.Column="5" Content="📄 Скачать шаблон Excel" Style="{StaticResource ActionButton}" Command="{Binding ExportTemplateCommand}"/>
            <Button Grid.Column="6" Content="💾 Сохранить в БД" Style="{StaticResource ActionButton}" Command="{Binding SaveCommand}" Background="#2E7D32"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Rows}" 
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  CanUserSortColumns="False"
                  AlternatingRowBackground="#F9F9F9"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия ученика" Binding="{Binding StudentLastName, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Имя ученика" Binding="{Binding StudentFirstName, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                <DataGridTextColumn Header="Отчество ученика" Binding="{Binding StudentPatronymic, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Цифра класса" Binding="{Binding StudentGrade, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Фамилия учителя" Binding="{Binding TeacherLastName, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Имя учителя" Binding="{Binding TeacherFirstName, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                <DataGridTextColumn Header="Отчество учителя" Binding="{Binding TeacherPatronymic, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Балл" Binding="{Binding Points, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>